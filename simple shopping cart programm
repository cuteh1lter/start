foods = []
prices = []
total = 0
while True:
    food = input("Please enter a food to buy (q to quit): ")
    if food.lower() == "q":
        break
    else:
        price = float(input(F"Please enter a price of {food}: $"))
        foods.append(food)
        prices.append(price)
print("----Your shopping list----")
for food in foods:
    print(food, end=" ")
for price in prices:
    total = total + price
print()
print(f"Total price: ${total}")
