import random
low_num = 0
high_num = 69
answer = random.randint(low_num, high_num)
guesses = 0
is_running = True
print("Welcome to the Python number guessing game")
print(f"Please enter a number between {low_num} and {high_num}")
while is_running:
    guess = input("Enter your guess: ")
    if guess.isdigit():
        guess = int(guess)
        guesses += 1
        if guess < low_num or guess > high_num:
            print("Out of range")
            print(f"Please enter a number between {low_num} and {high_num}")
        elif guess < answer:
            print("Too low. Try again")
        elif guess > answer:
            print("Too high. Try again")
        else:
            print(f"You guessed correctly. The number was {answer}")
            print(F"Your number of guesses is {guesses} ")
            is_running = False
    else:
        print("Invalid input")
        print(f"Please enter a number between {low_num} and {high_num}")
